{
  "version": "1.0",
  "name": "YOLO Detection — USB Camera",
  "description": "Standard YOLO object detection pipeline: USB camera → YOLO inference → draw boxes → stream. Replace MODEL_ID with a model ID from the Model Hub.",
  "nodes": [
    {
      "id": "cam",
      "type": "usb_camera",
      "config": {
        "device_index": 0,
        "width": 1280,
        "height": 720
      },
      "position": { "x": 50, "y": 200 }
    },
    {
      "id": "pre",
      "type": "preprocess",
      "config": {
        "width": 640,
        "height": 640,
        "normalize": "imagenet",
        "keep_aspect_ratio": true
      },
      "position": { "x": 300, "y": 200 }
    },
    {
      "id": "inf",
      "type": "model_inference",
      "config": {
        "model_id": "REPLACE_WITH_MODEL_ID",
        "device": "cpu"
      },
      "scaling": {
        "min_workers": 1,
        "max_workers": 2,
        "scale_up_buffer": 8,
        "scale_down_buffer": 2
      },
      "resources": {
        "max_fps": null,
        "gpu_memory_fraction": 0.5
      },
      "position": { "x": 550, "y": 200 }
    },
    {
      "id": "nms",
      "type": "nms",
      "config": {
        "confidence_threshold": 0.4,
        "iou_threshold": 0.45,
        "format": "yolov8"
      },
      "position": { "x": 800, "y": 200 }
    },
    {
      "id": "draw",
      "type": "draw_bbox",
      "config": {
        "thickness": 2,
        "show_confidence": true,
        "show_track_id": false
      },
      "position": { "x": 1050, "y": 200 }
    },
    {
      "id": "out",
      "type": "stream_viewer",
      "config": {},
      "position": { "x": 1300, "y": 200 }
    }
  ],
  "edges": [
    { "source": "cam",  "sourceHandle": "out",  "target": "pre",  "targetHandle": "in"  },
    { "source": "pre",  "sourceHandle": "out",  "target": "inf",  "targetHandle": "in"  },
    { "source": "inf",  "sourceHandle": "out",  "target": "nms",  "targetHandle": "in"  },
    { "source": "inf",  "sourceHandle": "raw",  "target": "nms",  "targetHandle": "raw" },
    { "source": "nms",  "sourceHandle": "frame","target": "draw", "targetHandle": "in"  },
    { "source": "nms",  "sourceHandle": "dets", "target": "draw", "targetHandle": "dets"},
    { "source": "draw", "sourceHandle": "out",  "target": "out",  "targetHandle": "in"  }
  ]
}
